# Database & IDEs
*.db
*.sqlite3
.vscode/
.idea/
.DS_Store

# Local AI Models
edge/models/*.pt
edge/models/*.onnx
edge/models/*.engine

# System & Local Buffers
edge/buffer/
*.mp4
*.avi
*.jpg
*.jpeg
*.png
